// =========== GENERAL SETTINGS ===========
nextflow.enable.dsl = 2

manifest {
    name = 'GVI-NF'
    description = 'Genomic Vulnerability Index Pipeline'
    version = '1.1'
    author = 'Your Team'
    homePage = 'https://github.com/yourorg/gvi-nf'
    mainScript = 'main.nf'
    nextflowVersion = '>=22.04.0'
}

// =========== EXECUTION PROFILES ===========
profiles {
    // LOCAL: Single machine (laptop/desktop)
    local {
        process.executor = 'local'
        process.cpus = 2
        process.memory = 4.GB
        process.time = 2.h
    }
    
    // HPC: SLURM/PBS/SGE clusters
    slurm {
        process.executor = 'slurm'
        process.cpus = 8
        process.memory = 16.GB
        process.time = 24.h
        process.queue = 'default'
        process.clusterOptions = '--account=myaccount'
    }
    
    // LSF: IBM LSF clusters
    lsf {
        process.executor = 'lsf'
        process.cpus = 8
        process.memory = 16.GB
        process.time = 24.h
    }
    
    // HIGH PERFORMANCE: Multi-node clusters
    hpc {
        process.executor = 'slurm'
        process.cpus = 16
        process.memory = 32.GB
        process.time = 48.h
        process.queue = 'compute'
    }
    
    // TEST: Lightweight testing
    test {
        process.executor = 'local'
        process.cpus = 1
        process.memory = 2.GB
        process.time = 30.m
    }
}

// =========== DEFAULT PARAMETERS ===========
params {
    // Input/Output
    input = null
    outdir = './results'
    
    // Analysis parameters
    genome_type = 'RNA'
    is_segmented = false
    host_species = 'Unknown'
    serotype = 'Unknown'
    selection_mode = 'FEL'
    
    // Module flags
    run_recomb = false
    run_evo_rate = false
    run_re = false
    
    // Computational
    threads = 4
    memory = '4.GB'
    
    // Output
    output_format = 'JSON'
    
    // Help
    help = false
    version = false
}

// =========== PROCESS DEFAULTS ===========
process {
    // Retry on failure (system-agnostic)
    errorStrategy = { task.attempt <= 3 ? 'retry' : 'terminate' }
    maxRetries = 3
    
    // Dynamic resource allocation
    cpus = { params.threads ?: 2 }
    memory = { params.memory ?: 4.GB }
    time = { 4.h }
}

// Clean up on success
cleanup = true

// =========== TOOL PATH DETECTION ===========
// Auto-detect common tool installation paths
env {
    // Standard system paths (usually sufficient)
    PATH = '$PATH:$HOME/.local/bin:$HOME/bin'
    
    // Allow Conda/Mamba paths if activated
    CONDA_PREFIX = '${CONDA_PREFIX:-}'
    
    // BioConda paths (if installed)
    BIOCONDA_PATH = '$HOME/mambaforge/envs/bioinformatics:$HOME/miniconda3/envs/bioinformatics'
}

// =========== LOGGING ===========
trace {
    enabled = false
    overwrite = true
    file = "${params.outdir}/trace.txt"
}

report {
    enabled = false
    overwrite = true
    file = "${params.outdir}/report.html"
}

timeline {
    enabled = false
    overwrite = true
    file = "${params.outdir}/timeline.html"
}

dag {
    enabled = false
    overwrite = true
    file = "${params.outdir}/dag.html"
}
